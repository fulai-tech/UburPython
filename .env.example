# 服务
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false

# Elasticsearch
ES_NODE=http://localhost:9200
ES_AUDIO_INDEX=somni_audio_materials
ES_TAG_VECTORS_INDEX=somni_audio_tag_dictionary

# MongoDB（Somni 数据同步源）
MONGO_URI=mongodb://user:password@host:27017/Fullive
MONGO_DB=Fullive

# comm-service gRPC
COMM_GRPC_HOST=bionode-test.fulai.tech
COMM_GRPC_PORT=443
COMM_GRPC_USE_TLS=true

# 检索参数
SIM_THRESHOLD=0.7
DEFAULT_TOP_K=10
# 检索步骤 1 是否按 sleep_stage_tags 做 nested 精确过滤
SEARCH_SLEEP_STAGE_FILTER_ENABLED=true

# Embedding（千问 text-embedding-v4 API；换模型/维度须重建 ES 并全量重算向量）
EMBEDDING_BACKEND=qwen_api
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_ONNX_DIR=models/onnx/bge-small-zh-v1.5
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_TIMEOUT_SEC=30
EMBEDDING_API_BATCH_SIZE=10

# Mongo → ES 差异同步（服务内每周定时 + 可手动 scripts/sync_es_from_comm.py）
SYNC_ENABLED=true
SYNC_INTERVAL_DAYS=7
SYNC_PAGE_SIZE=100
SYNC_BACKUP_DIR=data/sync_backup
SYNC_BACKUP_FILENAME=somni_audio_materials_backup.json

# 日志（控制台 + logs/uburnode.log 文件双写，每次请求自动记录）
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=uburnode.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
