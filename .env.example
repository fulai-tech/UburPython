# 服务
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false

# Elasticsearch
ES_NODE=http://localhost:9200
ES_AUDIO_INDEX=audio_materials
ES_TAG_VECTORS_INDEX=tag_vectors

# comm-service gRPC
COMM_GRPC_HOST=localhost
COMM_GRPC_PORT=50062

# 检索参数
SIM_THRESHOLD=0.8
DEFAULT_TOP_K=10

# Embedding 模型（BGE-M3，1024 维）
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# 日志（控制台 + logs/uburnode.log 文件双写，每次请求自动记录）
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=uburnode.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
