# 服务
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false

# Elasticsearch
ES_NODE=http://localhost:9200
ES_AUDIO_INDEX=audio_materials
ES_TAG_VECTORS_INDEX=tag_vectors

# comm-service gRPC
COMM_GRPC_HOST=bionode-test.fulai.tech
COMM_GRPC_PORT=443
COMM_GRPC_USE_TLS=true

# 检索参数
SIM_THRESHOLD=0.7
DEFAULT_TOP_K=10

# Embedding 模型（bge-small-zh-v1.5，512 维；换模型须重建 ES 并全量重算向量）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

# 日志（控制台 + logs/uburnode.log 文件双写，每次请求自动记录）
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=uburnode.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
